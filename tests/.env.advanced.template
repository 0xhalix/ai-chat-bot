# Environment Variables Template for Advanced Tools
# Copy this to your .env file and fill in your actual values

# ============================================================
# EXISTING BOT CREDENTIALS (Keep your current ones)
# ============================================================
BOT_TOKEN=your_telegram_bot_token_here
OPENROUTER_KEY=your_openrouter_key_here
GEMINI_KEY=your_gemini_key_here
DEEPSEEK_KEY=your_deepseek_key_here
HF_KEY=your_huggingface_key_here

# ============================================================
# GOOGLE CUSTOM SEARCH (For web_search tool)
# ============================================================
# Get these from:
# 1. API Key: https://console.cloud.google.com (Create API Key)
# 2. Search Engine ID: https://cse.google.com (Create custom search engine)

GOOGLE_CUSTOM_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# ============================================================
# DATABASE CONNECTION (For query_database tool)
# Host server connection details
# ============================================================

# Database type: postgresql, mysql, or sqlite
DB_TYPE=postgresql

# Host server IP/domain (NOT localhost if on server)
# Example: 192.168.1.100 or db.example.com
DB_HOST=localhost

# Database port
# PostgreSQL: 5432
# MySQL: 3306
DB_PORT=5432

# Database user (create limited user for security)
# Create with: CREATE USER botuser WITH PASSWORD 'password';
DB_USER=botuser

# Database password (strong password recommended)
DB_PASSWORD=YourSecurePasswordHere123!

# Database name (the actual database)
# Example: crypto_database, crypto_db, etc.
DB_NAME=crypto_database

# ============================================================
# DATABASE SETUP EXAMPLES
# ============================================================

# PostgreSQL Connection String (for reference):
# postgresql://botuser:YourSecurePasswordHere123!@192.168.1.100:5432/crypto_database

# MySQL Connection String (for reference):
# mysql://botuser:YourSecurePasswordHere123!@192.168.1.100:3306/crypto_database

# SQLite (local file, no auth needed):
# DB_TYPE=sqlite
# DB_HOST=localhost
# DB_NAME=/path/to/database.db

# ============================================================
# OPTIONAL: Advanced Settings
# ============================================================

# Tool call timeout (seconds)
TOOL_TIMEOUT_SEC=30

# Max tool calls per request
MAX_TOOL_CALLS=5

# Database query timeout (seconds)
DB_TIMEOUT_SEC=15

# Google Search max results (1-10)
GOOGLE_SEARCH_MAX_RESULTS=5

# Calculator precision (decimal places)
CALCULATOR_PRECISION=10

# Enable tool logging (true/false)
TOOL_DEBUG_LOG=true
